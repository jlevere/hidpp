# Logitech HID++ devices — allow user access without root.
#
# Install:
#   sudo cp 99-hidpp.rules /etc/udev/rules.d/
#   sudo udevadm control --reload
#
# Covers USB receivers (Unifying, Bolt, Lightspeed, Nano) and BLE direct connections.

# USB receivers and wired devices
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="046d", TAG+="uaccess"

# Bluetooth HID devices (bus type 0005 = Bluetooth)
SUBSYSTEM=="hidraw", KERNELS=="0005:046D:*", TAG+="uaccess"
